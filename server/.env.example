# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit secrets.
#   cp .env.example .env
# docker compose reads `.env` automatically.

# --- Database --------------------------------------------------------------------------------------
# Password for the Postgres `postgres` role. Used by both the db container and the relay's
# DATABASE_URL. Postgres is not published outside the compose network, but use a strong value anyway.
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Relay -----------------------------------------------------------------------------------------
# Phoenix endpoint signing key. Must be a long, stable secret. Generate one with EITHER:
#   docker run --rm pokepals-relay:latest bin/server eval "IO.puts(:crypto.strong_rand_bytes(48) |> Base.encode64())"
#   mix phx.gen.secret        # in a dev checkout with Elixir installed
SECRET_KEY_BASE=

# --- Public edge (Caddy / TLS) ---------------------------------------------------------------------
# The address Caddy serves on, which also picks the TLS mode:
#   pokepals.example.com  -> automatic, publicly-trusted Let's Encrypt cert (point this DNS at the host)
#   :443                  -> local self-signed cert for testing without a domain (clients must trust it)
# Clients then connect to wss://<SITE_ADDRESS>/ws
SITE_ADDRESS=

# Optional: contact email Let's Encrypt uses for cert-expiry notices. Leave blank to skip.
ACME_EMAIL=
