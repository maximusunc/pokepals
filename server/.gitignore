# Build artifacts and fetched deps — regenerated by `mix deps.get` / `mix compile`.
/_build/
/cover/
/deps/
/doc/
/.fetch
erl_crash.dump
*.ez
*.beam
/config/*.secret.exs
.elixir_ls/
# Godot web export output (index.html/.js/.wasm/.pck/…) — generated by exporting the "Web"
# preset, served by Plug.Static. Build artifact, not source; keep the dir, ignore its contents.
/priv/static/*
!/priv/static/.gitkeep
